<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.clawbridge.builder</string>
    <key>ProgramArguments</key>
    <array>
        <string>/usr/local/bin/node</string>
        <!-- Edit this path to match your deployment directory -->
        <string>/Users/CHANGEME/clawbridge/server.js</string>
    </array>
    <key>WorkingDirectory</key>
    <!-- Edit this path to match your deployment directory -->
    <string>/Users/CHANGEME/clawbridge</string>
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
        <key>HOME</key>
        <!-- Edit to your deploy user's home directory -->
        <string>/Users/CHANGEME</string>
        <key>BRIDGE_PORT</key>
        <string>3201</string>
    </dict>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>StandardOutPath</key>
    <string>/Users/CHANGEME/logs/clawbridge.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/CHANGEME/logs/clawbridge.log</string>
</dict>
</plist>
