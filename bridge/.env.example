BRIDGE_PORT=3201
BRIDGE_TOKEN=changeme
CLAUDE_CODE_OAUTH_TOKEN=<from claude setup-token>

# Optional — override if binaries are not on the default path
# CLAUDE_BIN=/usr/local/bin/claude
# PYTHON_BIN=/usr/bin/python3

# Optional — TangleClaw port registry URL (leave empty if not using TangleClaw)
# TANGLECLAW_URL=https://localhost:3102
